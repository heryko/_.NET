@page "/sentiment"
@rendermode InteractiveServer
@using Microsoft.Extensions.ML

@inject PredictionEnginePool<Lab4.MLModel.ModelInput, Lab4.MLModel.ModelOutput> PredictionPool

<PageTitle>Analiza nastroju</PageTitle>

<div class="container mt-4">
    <h1 class="text-center mb-4">How do you feel?</h1>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="mb-3">
                <label for="moodInput" class="form-label">Tell me how your day is going</label>
 
                <textarea id="moodInput"
                          class="form-control"
                          rows="4"
                          @bind="userInput"
                              placeholder="...">
                </textarea>
                </div>

                <button class="btn btn-primary w-100" @onclick="AnalyzeSentiment">
                    Analyze
                </button>
            </div>
        </div>

        @if (prediction != null)
        {
            <div class="mt-4 alert @GetAlertClass() shadow-sm">
                <h4 class="alert-heading">Result:</h4>
                <hr>
                <p class="mb-0"><strong>Your mood is:</strong> @prediction.PredictedLabel</p>
                <p class="mb-0"><strong>Classification confidence:</strong> @(Math.Round(GetConfidence() * 100, 2))%</p>
            </div>
        }
    </div>

@code {
    private string userInput = "";
    private Lab4.MLModel.ModelOutput? prediction;

    private async Task AnalyzeSentiment()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            var input = new Lab4.MLModel.ModelInput { Text = userInput };
            

            prediction = await Task.Run(() => PredictionPool.Predict(input));
        }
    }

    private float GetConfidence()
    {
        if (prediction?.Score != null && prediction.Score.Length > 0)
        {
            return prediction.Score.Max();
        }
        return 0;
    }

    private string GetAlertClass()
    {
        if (prediction?.PredictedLabel?.ToLower() == "positive") return "alert-success";
        if (prediction?.PredictedLabel?.ToLower() == "negative") return "alert-danger";
        return "alert-info";
    }
}